<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
x:Class="Okada.Views.RegisterPage"
Title="Join Okada Go Now">
    <VerticalStackLayout Spacing="20" Padding="20">
        <Label Text="Create Account" FontSize="32" HorizontalOptions="Center" />
        <Entry x:Name="PhoneEntry" Placeholder="Phone Number" Keyboard="Telephone" />
        <Button Text="Join Now" Clicked="OnRegisterClicked" />
    </VerticalStackLayout>
</ContentPage>

