<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Okada.Views.RiderLicenceCapturePage"
             Title="Rider Verification">
    <VerticalStackLayout Spacing="15"
                         Padding="20">
        <Label 
            Text="Take a picture of yourself holding driver's license"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />
        <Button Text="Capture with Camera"
                Clicked="OnCaptureClicked" />
        <Label Text="OR"
               HorizontalOptions="Center"
               FontSize="24"
               FontAttributes="Bold"
               Margin="20"/>
        <Button Text="Enter License Details Manually"
                Clicked="OnFormClicked" />
    </VerticalStackLayout>
</ContentPage>