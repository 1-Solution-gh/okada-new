<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Okada.Views.RiderFormPage"
             Title="License Form">
    <VerticalStackLayout Spacing="15"
                        Padding="20">
        <Label Text="Fill the Form Below"
       FontSize="18"
       FontAttributes="Bold"
       HorizontalOptions="Center" />
        <Entry x:Name="FullNameEntry"
       Placeholder="Full Name on License" />
        <Entry x:Name="DOBEntry"
       Placeholder="Date of Birth" />
        <Entry x:Name="AddressEntry"
       Placeholder="Current Registered Address"/>
        <Entry x:Name="LicenseNumberEntry"
       Placeholder="License Number" />
        <Entry x:Name="LicenseExpiryEntry"
       Placeholder="Expiry Date on License" />
        <Button Text="Upload License"
        Clicked="OnUploadClicked" />
        <Button Text="Submit"
        Clicked="OnSubmitClicked" />
    </VerticalStackLayout>
</ContentPage>
